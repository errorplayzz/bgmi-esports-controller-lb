# Server Configuration
PORT=3000
ADMIN_PASSWORD=admin123

# Google Sheets Configuration
# Option 1: Public Google Sheets (CSV export)
# Make your sheet public and use the sheet ID
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Option 2: Google Sheets API (for private sheets)
# Create a service account and download credentials.json
# Place credentials.json in the server folder
USE_GOOGLE_API=false

# Sheet Configuration
SHEET_NAME=Sheet1
DATA_REFRESH_INTERVAL=10000

# Tournament Configuration
TOURNAMENT_NAME=BGMI Esports Championship 2026
